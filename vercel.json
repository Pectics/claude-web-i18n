{
  "buildCommand": "bash ./build.sh",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/i18n/:locale.json",
      "destination": "/:locale/_i18n_:locale.json"
    },
    {
      "source": "/i18n/statsig/:locale.json",
      "destination": "/:locale/_i18n_statsig_:locale.json"
    }
  ]
}
